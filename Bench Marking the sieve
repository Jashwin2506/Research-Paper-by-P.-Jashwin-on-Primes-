{"nbformat":4,"nbformat_minor":0,"metadata":{"colab":{"provenance":[],"authorship_tag":"ABX9TyOhFBV8Ex95VYE8KJN6cXZg"},"kernelspec":{"name":"python3","display_name":"Python 3"},"language_info":{"name":"python"}},"cells":[{"cell_type":"code","execution_count":null,"metadata":{"id":"bx3FIoLwyAzf"},"outputs":[],"source":["import time\n","\n","def primes_up_to(n):\n","    \"\"\"Return a list of all primes <= n using the Sieve of Eratosthenes.\"\"\"\n","    if n < 2:\n","        return []\n","\n","    is_prime = [True] * (n + 1)\n","    is_prime[0] = is_prime[1] = False\n","\n","    for i in range(2, int(n ** 0.5) + 1):\n","        if is_prime[i]:\n","            for multiple in range(i * i, n + 1, i):\n","                is_prime[multiple] = False\n","\n","    return [i for i, prime in enumerate(is_prime) if prime]\n","\n","\n","test_values = [1233000000]\n","\n","print(\"Benchmarking Sieve of Eratosthenes\")\n","print(\"-\" * 50)\n","\n","for n in test_values:\n","    start = time.perf_counter()\n","\n","    primes = primes_up_to(n)\n","\n","    end = time.perf_counter()\n","\n","    runtime = end - start\n","\n","    print(\n","        f\"N = {n:<8} \"\n","        f\"Primes found = {len(primes):<8} \"\n","        f\"Time = {runtime:.6f} seconds\"\n","    )"]}]}
